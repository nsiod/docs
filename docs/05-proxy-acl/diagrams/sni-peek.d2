shape: sequence_diagram

Client: "Remote Client"
SM: "smoltcp (netstack)"
Relay: "relay_https_connection\n(nsn/src/main.rs)"
Peek: "sni_peek::parse_tls_sni"
Router: "ServiceRouter"
ACL: "AclEngine"
Proxy: "TcpStream (backend)"
SVC: "HTTPS Backend"

Client -> SM: "TCP SYN → dst_port=443"
SM -> Relay: "NewTcpConnection (local=:443)"
Client -> SM: "TLS ClientHello (record 0x16 / handshake 0x01)"
SM -> Relay: "data_rx.recv() 首个 chunk"
Relay -> Peek: "parse_tls_sni(&first)"
Peek -> Relay: "Some('api.example.com')"
Relay -> Router: "resolve_by_sni(src, dst, sni)"
Router -> Router: "find_named_by_sni(sni)"
Router -> ACL: "is_allowed(src_ip, dst_ip, 443, Tcp)"
ACL -> Router: "allowed=true"
Router -> Router: "resolve_host(service.host, service.port)"
Router -> Relay: "ResolvedService{target}"
Relay -> Proxy: "TcpStream::connect(target)"
Relay -> Proxy: "write_all(first) — 完整转发 ClientHello"
Relay -> Proxy: "双向 relay 后续字节"
Proxy -> SVC: "TLS 握手继续 (后端完成握手)"
SVC -> Client: "ServerHello / 应用数据"
