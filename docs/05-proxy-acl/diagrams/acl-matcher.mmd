%% acl-matcher.mmd — ACL 匹配流程
%% 引用: crates/acl/src/engine.rs:141  crates/acl/src/matcher.rs:50
flowchart TD
    Start([AccessRequest<br/>src_ip, dst_ip, dst_port, proto]) --> Iter{遍历编译后<br/>的 CompiledRule}

    Iter -->|rule i| SrcCheck{src 匹配?<br/>CIDR/alias/'*'}
    SrcCheck -- No --> NextRule[下一条规则]
    SrcCheck -- Yes --> DstCheck{dst.host 匹配?<br/>CIDR/alias/'*'}
    DstCheck -- No --> NextRule
    DstCheck -- Yes --> PortCheck{dst.port 匹配?<br/>Any/Single/Range/List}
    PortCheck -- No --> NextRule
    PortCheck -- Yes --> ProtoCheck{proto 匹配?<br/>None → 任意<br/>Tcp/Udp → 精确}
    ProtoCheck -- No --> NextRule
    ProtoCheck -- Yes --> Accept[[AclDecision<br/>allowed=true<br/>matched_rule_index=i]]

    NextRule --> Iter
    Iter -->|规则列表用尽| Deny[[AclDecision<br/>allowed=false<br/>reason=denied: no matching accept rule]]

    Accept --> End([return])
    Deny --> End
