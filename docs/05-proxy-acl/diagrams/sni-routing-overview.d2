direction: right

C: "Remote Client"
SM: "smoltcp"
R: "relay_https_connection"
S: "parse_tls_sni"
RT: "ServiceRouter.resolve_by_sni"
SVC: "ServiceDef"
A: "AclEngine.is_allowed"
T: "backend SocketAddr" { shape: oval }
B: "Backend :443"

C -> SM: "TCP :443"
SM -> R: "NewTcpConnection"
R -> S: "first chunk"
S -> RT: "sni str"
RT -> SVC: "find_named_by_sni"
RT -> A: "AccessRequest 443/Tcp"
RT -> T: "resolve_host"
R -> B: "write_all first ClientHello"
R <-> B: "relay TLS records"
