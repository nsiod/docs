%% MultiControlPlane data flow: per-NSD ControlPlane → tagged updates → merger loop → downstream
flowchart TB
    subgraph NSDs[NSD Endpoints]
        NSD1[(NSD-1<br/>primary)]
        NSD2[(NSD-2<br/>secondary)]
        NSD3[(NSD-3<br/>tenant-X)]
    end

    subgraph MCP[MultiControlPlane multi.rs:131]
        direction TB
        CP1[ControlPlane #1<br/>+ AuthClient #1<br/>+ ServiceReport]
        CP2[ControlPlane #2<br/>+ AuthClient #2<br/>+ ServiceReport]
        CP3[ControlPlane #3<br/>+ AuthClient #3<br/>+ ServiceReport]

        UPD[/"mpsc::Sender NsdUpdate (cap 64)"/]
        STORE[(NsdConfigStore<br/>merge.rs:149<br/>HashMap nsd_id → cfg)]
        MERGER{Merger loop<br/>multi.rs:295}
    end

    subgraph DOWN[Downstream Receivers]
        WG_OUT[wg_rx → tunnel-wg]
        PROXY_OUT[proxy_rx → nat]
        ACL_OUT[acl_rx → acl]
        GW_OUT[gateway_rx → connector]
        ROUTE_OUT[routing_rx → nsgw/nsc]
        DNS_OUT[dns_rx → nsc]
        STATUS_OUT[status_rx → monitor /api/status]
        TOKEN_OUT[token_refresh_rx → heartbeat]
    end

    NSD1 -- "SSE wg/proxy/acl/gateway/routing/dns/token_refresh" --> CP1
    NSD2 -- "SSE wg/proxy/acl/gateway/routing/dns/token_refresh" --> CP2
    NSD3 -- "SSE wg/proxy/acl/gateway/routing/dns/token_refresh" --> CP3

    CP1 -- tag id=NSD-1 --> UPD
    CP2 -- tag id=NSD-2 --> UPD
    CP3 -- tag id=NSD-3 --> UPD

    UPD --> MERGER
    MERGER --> STORE
    STORE -. "merged_wg() peers UNION (dedupe public_key)" .-> MERGER
    STORE -. "merged_proxy() rules UNION (dedupe resource_id)" .-> MERGER
    STORE -. "merged_acl() hosts/acls/tests INTERSECTION" .-> MERGER

    MERGER -- merged WgConfig --> WG_OUT
    MERGER -- merged ProxyConfig --> PROXY_OUT
    MERGER -- merged AclConfig --> ACL_OUT
    MERGER -- pass-through GatewayConfig --> GW_OUT
    MERGER -- pass-through RoutingConfig --> ROUTE_OUT
    MERGER -- pass-through DnsConfig --> DNS_OUT
    MERGER -- nsd_id on each cfg arrival --> STATUS_OUT
    MERGER -- token_refresh forwarded --> TOKEN_OUT

    classDef nsd fill:#fee,stroke:#a33;
    classDef cp fill:#eef,stroke:#33a;
    classDef merge fill:#efe,stroke:#393;
    classDef out fill:#fff8e1,stroke:#aa8;
    class NSD1,NSD2,NSD3 nsd
    class CP1,CP2,CP3 cp
    class STORE,MERGER merge
    class WG_OUT,PROXY_OUT,ACL_OUT,GW_OUT,ROUTE_OUT,DNS_OUT,STATUS_OUT,TOKEN_OUT out
