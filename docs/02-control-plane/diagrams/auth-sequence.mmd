%% NSN ↔ NSD authentication paths
%% - First-run with authkey
%% - First-run with OAuth2 device flow
%% - Subsequent runs with Ed25519 signature
sequenceDiagram
    autonumber
    participant NSN as NSN (control crate)
    participant State as MachineState<br/>(local, on disk)
    participant Browser as User Browser
    participant NSD as NSD (control center)

    Note over NSN,State: Generate / load identity<br/>Ed25519 (machinekey) + X25519 (peerkey)<br/>state.rs:147 load_or_create_for_realm()

    NSN->>NSD: GET /api/v1/info
    NSD-->>NSN: NsdInfo {nsd_type, realm, auth_methods, version}

    alt First run with authkey
        NSN->>NSD: POST /api/v1/machine/register<br/>{auth_key, machine_id?, machine_key_pub, peer_key_pub, hostname, os, version, system_info}
        NSD-->>NSN: 200 {machine_id, server_peer_key_pub, server_endpoint, domain_base?}
        NSN->>State: set_registered(...)
        NSN->>State: save() machinekey.json + registrations/{realm}.json (0600)
    else First run with OAuth2 device flow (RFC 8628)
        NSN->>NSD: POST /api/v1/device/code {client_id:"nsio-connector"}
        NSD-->>NSN: {device_code, user_code, verification_uri[_complete], expires_in, interval}
        NSN-->>Browser: print(verification_uri_complete + user_code)
        Browser->>NSD: User opens URL & approves device
        loop poll every interval seconds (deadline = expires_in + 5s)
            NSN->>NSD: POST /api/v1/device/token<br/>{device_code, grant_type:"urn:ietf:params:oauth:grant-type:device_code"}
            alt pending
                NSD-->>NSN: {error:"authorization_pending"|"slow_down"}
            else approved
                NSD-->>NSN: {access_token}
            else error
                NSD-->>NSN: {error:"expired_token"|"access_denied"|...}
                NSN--xNSN: Error::Auth(...)
            end
        end
        NSN->>NSD: POST /api/v1/machine/register<br/>Authorization: Bearer access_token
        NSD-->>NSN: 200 {machine_id, server_peer_key_pub, server_endpoint, domain_base?}
        NSN->>State: set_registered + save
    else Subsequent run (already registered)
        Note over NSN: skip register; reuse machine_id<br/>auth.rs:238 authenticate()
    end

    Note over NSN: Build message = "{machine_id}:{unix_secs}"<br/>signature = Ed25519(signing_key, message)
    NSN->>NSD: POST /api/v1/machine/auth<br/>{machine_id, machine_key_pub, timestamp, signature}
    NSD-->>NSN: 200 {token: "<JWT>"}

    Note over NSN,NSD: Now ready to POST /services/report and<br/>open SSE GET /api/v1/config/stream<br/>(see sse-config.mmd)
