direction: right

e: "SSE 事件\n{payload, sig{kid, value}}"
l1: "查找 kid 对应的\nSigningCert (来自 signing_certs 事件)"
drop1: "丢弃 + WARN"
l2: "验 root_sig:\nrealm_root_key_pub 是否签了这张 cert?"
drop2: "丢弃 + WARN"
l3: "验事件 sig.value:\ncert.pub 是否签了 payload digest?"
drop3: "丢弃 + WARN"
apply: "应用到 merge.rs / 数据面"

e -> l1
l1 -> drop1: "未找到或已过期"
l1 -> l2
l2 -> drop2: "失败"
l2 -> l3
l3 -> drop3: "失败"
l3 -> apply
