%% NSGW internal component layering
%% Source: tests/docker/nsgw-mock/src/index.ts + entrypoint.sh + tmp/gateway/main.go
graph TB
    subgraph External["External connections"]
        NSC["NSC / NSN client<br/>WG or WSS"]
        NSD["NSD control plane<br/>HTTPS + SSE"]
    end

    subgraph Container["NSGW container (single process tree)"]
        subgraph EntryPoint["entrypoint.sh (PID 1 bootstrap)"]
            EP1["wg genkey / pubkey"]
            EP2["ip link add wg0 + /16<br/>NET_ADMIN required"]
            EP3["sysctl ip_forward=1"]
            EP4["openssl self-signed<br/>+ tls.yml"]
        end

        subgraph Traefik["traefik v3.6.13 (background)"]
            T_EP_WEB["entryPoint web:8080"]
            T_EP_TLS["entryPoint websecure:443"]
            T_FP["file provider<br/>watch /etc/traefik/dynamic"]
            T_RT["routers + services<br/>(from routes.yml)"]
            T_TLS_STORE["TLS store 'default'<br/>(from tls.yml)"]
        end

        subgraph Kernel["Linux kernel"]
            WG0["wg0 interface<br/>UDP :51820<br/>allowed-ips table"]
            RT["IP routing + forward"]
        end

        subgraph Bun["Bun process (PID 1 child, foreground)"]
            B_CFG["loadConfig()<br/>env → Config"]
            B_HEALTH["Bun.serve :9091<br/>/ready /server-pubkey<br/>/admin/shutdown"]
            B_WSS["Bun.serve :9443<br/>/relay /client /probe-open<br/>(ENABLE_WSS_RELAY)"]
            B_REG["registerWithNsd()<br/>+ subscribeToNsdSse()"]
            B_WG["wg-setup.ts<br/>addPeer / removePeer CLI"]
            B_TRA["traefik-config.ts<br/>atomic write routes.yml"]
        end
    end

    EP1 --> EP2 --> EP3 --> EP4
    EP4 --> Traefik
    EP4 --> Bun

    NSC -->|"UDP :51820 WG"| WG0
    NSC -->|"HTTPS :443"| T_EP_TLS
    NSC -->|"WSS :9443"| B_WSS

    T_EP_TLS --> T_TLS_STORE
    T_EP_TLS --> T_RT
    T_EP_WEB --> T_RT
    T_RT -->|"backend http://wg_ip:port"| RT
    WG0 <--> RT

    NSD <-->|"POST /machine/register<br/>POST /gateway/report<br/>GET /config/stream (SSE)"| B_REG
    B_REG -->|"wg_config"| B_WG
    B_WG -->|"wg set wg0 peer"| WG0
    B_REG -->|"routing_config"| B_TRA
    B_TRA -->|"atomic rename"| T_FP
    T_FP -->|"reload"| T_RT

    B_CFG --> B_HEALTH
    B_CFG --> B_WSS
    B_CFG --> B_REG
