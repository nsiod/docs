# traefik -> NSGW wg0 -> NSN ServiceRouter 端到端数据流

shape: sequence_diagram

B: "Browser"
T: "traefik :443"
W: "NSGW wg0\n(kernel WG)"
N: "NSN gotatun\n+ ServiceRouter"
S: "Real service\n127.0.0.1:80"

B -> T: "GET https://app.example.com/\nSNI: app.example.com"
T -> T: "TLS 终结 (default cert)"
T -> T: "router match Host(app.example.com)"
T -> T: "service -> http://10.0.0.2:10000"
T -> W: "TCP connect 10.0.0.2:10000\n(plain HTTP)"
W -> W: "kernel WG encap\n(allowed-ips 10.0.0.2/32 -> NSN peer)"
W -> N: "UDP :51820 WG packet"
N -> N: "gotatun decap\n-> smoltcp or HybridNatSend"
N -> N: "ServiceRouter lookup virtual_port 10000"
N -> N: "ACL check (allow)"
N -> S: "TCP connect 127.0.0.1:80"
S -> N: "HTTP response"
N -> W: "WG encap"
W -> T: "TCP bytes"
T -> B: "HTTPS response"
