%% WsFrame multiplexing over a single WebSocket
%% Source: crates/tunnel-ws/src/lib.rs
graph LR
    subgraph Client["NSGW relay peer"]
        OpenA[Open stream_id=1<br/>target 10.0.0.5:80 TCP]
        OpenB[Open stream_id=2<br/>target 10.0.0.5:53 UDP]
        Data1[Data stream_id=1]
        Data2[Data stream_id=2]
    end

    subgraph WS["Single wss:// connection<br/>Message::Binary frames"]
        Pipe((" WsFrame stream "))
    end

    subgraph NSN["NSN WsTunnel (tunnel-ws/src/lib.rs:279)"]
        Decode["WsFrame::decode()<br/>lib.rs:183"]
        Dispatch["dispatch_frame()<br/>lib.rs:470"]
        ACLCheck["check_target_allowed()<br/>lib.rs:434"]
        Registry["DashMap&lt;u32, StreamHandle&gt;<br/>lib.rs:371"]
        WriteTask["Write task<br/>lib.rs:362"]

        subgraph RelayTasks["Per-stream relay tasks"]
            TcpRelay["relay_tcp()<br/>lib.rs:593"]
            UdpRelay["relay_udp()<br/>lib.rs:648"]
        end
    end

    subgraph Services["Local services"]
        Tcp80[TCP :80]
        Udp53[UDP :53]
    end

    OpenA --> Pipe
    OpenB --> Pipe
    Data1 --> Pipe
    Data2 --> Pipe

    Pipe -->|Message::Binary| Decode
    Decode --> Dispatch
    Dispatch -->|Open| ACLCheck
    ACLCheck -->|allow| Registry
    ACLCheck -.deny.-> Close[Close frame back]
    Registry -->|spawn| TcpRelay
    Registry -->|spawn| UdpRelay

    Dispatch -->|Data| Registry
    Registry -->|data_tx mpsc| TcpRelay
    Registry -->|data_tx mpsc| UdpRelay

    TcpRelay -->|TcpStream::connect| Tcp80
    UdpRelay -->|UdpSocket bind+connect| Udp53

    TcpRelay -->|encode Data/Close| WriteTask
    UdpRelay -->|encode Data| WriteTask
    WriteTask -->|Message::Binary| Pipe
    Close --> WriteTask
