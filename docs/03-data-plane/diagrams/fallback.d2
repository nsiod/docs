shape: sequence_diagram

NSN: "NSN ConnectorManager"
Peer: "NSGW peer endpoint"
Relay: "wss://{gw}/relay"

NSN -> NSN: "connect(wg_config) — lib.rs:205"

retries: "3 attempts, 3s delay" {
  NSN -> Peer: "UDP 148B probe to peer.endpoint (lib.rs:254)"
  ok: "UDP reachable" {
    Peer -> NSN: "reply / send succeeds"
    NSN -> NSN: "active = Transport::Udp"
    NSN."done — TunnelManager drives WG"
  }
  err: "send fails / ICMP unreachable" {
    Peer -> NSN: "error"
  }
}

NSN."All 3 UDP attempts failed → fallback"

NSN -> Relay: "WSS connect with Bearer token\n(tunnel-ws/src/lib.rs:308)"
Relay -> NSN: "101 Switching Protocols"
NSN -> NSN: "active = Transport::Wss(WsTunnel)"

wss_par: "Parallel: WSS data-plane + upgrade probe" {
  data: "WSS data-plane" {
    NSN -> Relay: "Message::Binary(WsFrame) * N"
    Relay -> NSN: "Message::Binary(WsFrame) * N"
  }
  probe: "Periodic upgrade probe (every 300s, lib.rs:328)" {
    NSN -> Peer: "UDP probe"
    recovered: "UDP recovered" {
      Peer -> NSN: "reply"
      NSN -> NSN: "abort proxy_handle\nactive = Transport::Udp"
      NSN."seamless upgrade WSS → UDP"
    }
    blocked: "still blocked" {
      Peer -> NSN: "timeout / err"
      NSN."stay on WSS"
    }
  }
}
