%% Multi-gateway connector + health state machine
%% Source: crates/connector/src/multi.rs
flowchart TB
    subgraph Config["Static config (GatewayConfig x N)"]
        G1[nsgw-1<br/>priority=1]
        G2[nsgw-2<br/>priority=2]
        G3[nsgw-3<br/>priority=3 disabled]
    end

    subgraph MGM["MultiGatewayManager (multi.rs:152)"]
        direction TB
        Strat{GatewayStrategy<br/>multi.rs:84}
        subgraph FSM["GatewayStatus state machine (multi.rs:50)"]
            Pending((Pending))
            Reconn((Reconnecting<br/>attempt=n))
            Conn((Connected<br/>since=t))
            Failed((Failed<br/>reason))
            Disabled((Disabled))
        end
        Selector["select_gateway()<br/>multi.rs:272"]
        Events["event_tx<br/>GatewayEvent::*<br/>multi.rs:24"]
    end

    subgraph Consumers["Consumers"]
        AppState[AppState / Monitor API<br/>/api/gateways]
        NsdReport[NSD gateway_report]
        Router[ServiceRouter<br/>gateway selection]
    end

    G1 --> MGM
    G2 --> MGM
    G3 --> MGM

    Pending -- "mark_connected(id,transport,latency)" --> Conn
    Pending -- "mark_failed" --> Failed
    Conn -- "mark_failed" --> Failed
    Failed -- "mark_reconnecting(attempt)" --> Reconn
    Reconn -- "mark_connected" --> Conn
    Reconn -- "mark_failed" --> Failed
    Disabled -.admin enable.-> Pending

    Strat -->|LowestLatency| Selector
    Strat -->|RoundRobin<br/>rr_cursor| Selector
    Strat -->|PriorityFailover| Selector

    Conn --> Selector
    Selector --> Router

    MGM -- "emit()" --> Events
    Events -->|try_send| AppState
    Events -->|mark_* hooks| NsdReport
