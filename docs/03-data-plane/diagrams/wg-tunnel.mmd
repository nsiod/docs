%% gotatun WireGuard 隧道报文流
%% Source: crates/tunnel-wg/src/lib.rs
graph TB
    subgraph ControlPlane["Control Plane"]
        WgCfg[WgConfig event<br/>via wg_config_rx]
    end

    subgraph TunnelManager["TunnelManager (tunnel-wg/src/lib.rs:117)"]
        RunLoop[run() select loop<br/>lib.rs:186]
        BuildDev[build_device()<br/>lib.rs:269]
        StatusPoll[spawn_status_poller()<br/>lib.rs:516]
    end

    subgraph Device["gotatun Device (generation N)"]
        UAPI[UapiServer<br/>device.uapi.UapiServer]
        CryptoCore[Noise + AEAD<br/>handshake / encrypt / decrypt]
        UDPSock[UdpSocketFactory]
        PeerTable[Peer table<br/>allowed_ips routing]
    end

    subgraph IPAdapter["IP Adapter (userspace mode)"]
        IpSend["NsnIpSend::send()<br/>ip_adapter.rs:25"]
        IpRecv["NsnIpRecv::recv()<br/>ip_adapter.rs:50"]
        AclFilter["AclFilteredSend<br/>acl_ip_adapter.rs:90"]
    end

    subgraph TunPath["TUN Hybrid Path (TUN mode)"]
        HybridSend[HybridNatSend<br/>tunnel-wg/src/lib.rs:47]
        HybridRecv[HybridNatRecv]
        TunFD[TunDevice<br/>MTU 1420]
    end

    subgraph Downstream["Downstream"]
        Netstack[smoltcp netstack]
        KernTCP[Kernel TCP<br/>local services]
    end

    WgCfg -->|WgConfig| RunLoop
    RunLoop -->|1. stop old dev<br/>2. build new| BuildDev
    BuildDev -->|with_uapi| UAPI
    BuildDev -->|with_peer| PeerTable
    BuildDev -->|with_ip_pair| IpSend
    BuildDev -->|with_ip_pair| IpRecv
    BuildDev -->|with_default_udp| UDPSock

    UDPSock -->|encrypted UDP:51820| CryptoCore
    CryptoCore -->|decrypted IP| IpSend
    IpSend -.->|mpsc| AclFilter
    AclFilter -->|allowed TCP/UDP| Netstack

    Netstack -->|reply pkt| IpRecv
    IpRecv -->|mpsc| CryptoCore
    CryptoCore -->|encrypted| UDPSock

    CryptoCore -.TUN mode.-> HybridSend
    HybridSend -->|local DNAT| TunFD
    HybridSend -->|remote proxy_tx| Netstack
    TunFD --> KernTCP
    KernTCP --> HybridRecv
    HybridRecv -->|reverse NAT| CryptoCore

    RunLoop --> StatusPoll
    StatusPoll -->|Request::Get| UAPI
    UAPI -->|Response::Get<br/>last_handshake / bytes| StatusPoll
    StatusPoll -->|GatewayStatusUpdate| ControlPlane
