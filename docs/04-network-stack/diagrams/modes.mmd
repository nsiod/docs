%% modes.mmd
%% TUN 与 UserSpace 两种数据面模式的俯视对比
%% UserSpace 装配: crates/nsn/src/main.rs:1005
%% TUN 装配:       crates/tunnel-wg/src/lib.rs:382
flowchart TB
    subgraph CLIENT["NSC / 远端用户"]
        U[User]
    end
    subgraph GW["NSGW"]
        WG[WireGuard / WSS]
    end

    subgraph USER["NSN · UserSpace 模式 &#40;default, 无 root&#41;"]
        G1[gotatun decrypt]
        NS1[NetStack::poll<br/>smoltcp]
        SR1[ServiceRouter.resolve<br/>ACL + services + DNS]
        PX1[proxy<br/>TcpStream / UdpSocket]
        SVC1A[(本地服务<br/>127.0.0.1:*)]
        SVC1B[(远端服务<br/>192.168.x.x:*)]
        G1 --> NS1 --> SR1 --> PX1
        PX1 --> SVC1A
        PX1 --> SVC1B
    end

    subgraph TUN["NSN · TUN 模式 &#40;需 CAP_NET_ADMIN&#41;"]
        G2[gotatun decrypt]
        H[HybridNatSend<br/>ACL + DNAT + SNAT + conntrack]
        KT[(kernel TUN)]
        LSVC[(本地服务<br/>零 proxy)]
        NS2[netstack smoltcp<br/>&#40;只处理 remote&#41;]
        SR2[ServiceRouter.resolve]
        PX2[proxy]
        RSVC[(远端服务)]
        HR[HybridNatRecv<br/>reverse NAT + smoltcp_out merge]
        G2 --> H
        H -- "is_local=true<br/>DNAT+SNAT+conntrack" --> KT --> LSVC
        H -- "is_local=false<br/>proxy_tx" --> NS2 --> SR2 --> PX2 --> RSVC
        LSVC -. reply .-> KT --> HR
        NS2 -. smoltcp_out_tx .-> HR
        HR --> ENC2[gotatun encrypt]
    end

    U --> WG
    WG --> G1
    WG --> G2
    NS1 -. tx_out .-> ENC1[gotatun encrypt] --> WG
    ENC2 --> WG
    WG --> U

    classDef mode fill:#f7f7ff,stroke:#99c
    class USER,TUN mode
