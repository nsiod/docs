%% nat-dnat.mmd
%% TUN 模式 HybridNatSend 的 ACL + DNAT + local/intercept/drop 决策
%% 源码: crates/nat/src/packet_nat.rs:225 (HybridNatSend::send)
flowchart TD
    START([Packet&lt;Ip&gt; into HybridNatSend::send]) --> FT[parse_five_tuple<br/>packet_nat.rs:100]
    FT -- None / ICMP / IPv6 --> DROP0[drop: return Ok &#40;&#41;]
    FT -- FiveTuple --> ACL{AclEngine 已加载?}
    ACL -- no --> LOOKUP[services.find_named_by_port<br/>dst_port, proto]
    ACL -- yes --> ACLQ{acl.is_allowed?}
    ACLQ -- false --> DROP1[tracing::debug<br/>TUN: ACL denied packet]
    ACLQ -- true --> LOOKUP
    LOOKUP -- None --> DROP2[drop: no matching service]
    LOOKUP -- &#40;name, svc&#41; --> ISLOCAL{svc.is_local?}

    ISLOCAL -- yes --> PARSEIP[svc.host.parse::&lt;Ipv4Addr&gt;]
    PARSEIP -- Err &#40;domain&#41; --> DROP3[tracing::warn<br/>host not IPv4 literal]
    PARSEIP -- Ok real_ip --> DNAT[DNAT<br/>dst_ip := real_ip<br/>dst_port := real_port]
    DNAT --> SNAT[SNAT<br/>src_ip := tun_ip]
    SNAT --> CT["conntrack.insert &#40;reverse key&#41;<br/>proto, real_ip:real_port ↔ tun_ip:peer_port"]
    CT --> CSUM[recalc_ip_checksum<br/>recalc_transport_checksum]
    CSUM --> SENDTUN[inner.send Packet&lt;Ip&gt;<br/>→ kernel TUN]
    SENDTUN --> KERN[Linux kernel<br/>local service<br/>127.0.0.1]

    ISLOCAL -- no --> RAW["proxy_tx.send raw bytes"]
    RAW -- channel closed --> ERR[Err: BrokenPipe]
    RAW -- ok --> NETSTACK[(netstack::inject_rx)]
    NETSTACK --> SMOL[smoltcp → ServiceRouter → proxy → remote service]

    classDef drop fill:#fee,stroke:#c33,color:#900
    classDef accept fill:#efe,stroke:#393,color:#060
    class DROP0,DROP1,DROP2,DROP3,ERR drop
    class SENDTUN,NETSTACK,KERN,SMOL accept
