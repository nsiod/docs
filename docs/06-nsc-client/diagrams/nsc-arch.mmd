flowchart TB
  subgraph User["User terminal"]
    APP["App: ssh / curl / psql / browser"]
    OSRES["OS resolver<br/>/etc/resolv.conf<br/>→ 127.0.0.53"]
  end

  subgraph NSC["NSC (Rust binary)"]
    direction TB
    subgraph CLI["CLI (main.rs)"]
      ARGS["Cli::parse()<br/>--data-plane / --auth-key<br/>--http-proxy / --log-dir"]
      MLOOP["main loop<br/>tokio::select!"]
    end

    subgraph CTRL["Control-plane side"]
      AUTH["AuthClient<br/>(common::MachineState)"]
      CP["ControlPlane<br/>(SSE subscriber)"]
    end

    subgraph STATE["Shared state (Arc + RwLock)"]
      ROUTER["NscRouter<br/>sites_by_name / sites_by_vip<br/>routes / gateways"]
      DNSMAP["DnsRecords<br/>domain → VIP"]
      VIPALLOC["VipAllocator<br/>127.11.x.x or 100.64.x.x"]
    end

    subgraph LOCAL["Local access layer"]
      DNSS["dns.rs<br/>UDP :53 on 127.0.0.53"]
      VIPPROX["proxy.rs<br/>TCP listeners on VIP:port"]
      HTTPP["http_proxy.rs<br/>(optional, --http-proxy)"]
    end
  end

  subgraph Cloud["NSIO control plane / edge"]
    NSD["NSD<br/>routing_config<br/>dns_config<br/>gateway_config"]
    NSGW["NSGW<br/>WSS relay + kernel WG"]
    NSN["NSN (site node)"]
  end

  ARGS --> MLOOP
  APP --> OSRES --> DNSS
  APP -. HTTP_PROXY .-> HTTPP
  APP -- TCP --> VIPPROX

  AUTH --> CP
  CP == SSE events ==> MLOOP
  NSD == SSE ==> CP

  MLOOP -- "routing_rx<br/>dns_rx<br/>gw_rx" --> ROUTER
  MLOOP --> DNSMAP
  MLOOP -- allocate(site) --> VIPALLOC

  DNSS -- reads --> DNSMAP
  VIPPROX -- reads --> ROUTER
  HTTPP -- reads --> DNSMAP

  VIPPROX == "WSS + CMD_OPEN_V4<br/>(WsFrame)" ==> NSGW
  HTTPP -- 'internal TCP' --> VIPPROX
  NSGW -- "WG / WSS" --> NSN

  classDef cli fill:#e0f2fe,stroke:#0369a1,color:#111
  classDef ctrl fill:#fef3c7,stroke:#b45309,color:#111
  classDef state fill:#dcfce7,stroke:#166534,color:#111
  classDef local fill:#ede9fe,stroke:#5b21b6,color:#111
  classDef cloud fill:#fee2e2,stroke:#b91c1c,color:#111

  class ARGS,MLOOP cli
  class AUTH,CP ctrl
  class ROUTER,DNSMAP,VIPALLOC state
  class DNSS,VIPPROX,HTTPP local
  class NSD,NSGW,NSN cloud
