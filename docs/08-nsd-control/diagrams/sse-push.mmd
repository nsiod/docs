%% SSE push: NSN/NSGW state change → NSD broadcast to subscribers.
%% Source: tests/docker/nsd-mock/src/registry.ts:handleServicesReport / handleGatewayReport
sequenceDiagram
    autonumber
    participant NSN_A as NSN-A
    participant NSGW
    participant NSD
    participant NSN_B as NSN-B (其他订阅者)
    participant NSC as NSC (订阅者)

    Note over NSN_A,NSC: 已建立 SSE 订阅的状态

    rect rgb(240, 248, 255)
        Note over NSN_A,NSD: 事件源 1：NSN 上报 services
        NSN_A->>NSD: POST /api/v1/services/report { services, strict_mode }
        NSD->>NSD: nsnServices[NSN_A] = services<br/>重算 wg/proxy/routing/dns
        NSD-->>NSN_A: SSE: wg_config
        NSD-->>NSN_A: SSE: gateway_config
        NSD-->>NSN_A: SSE: proxy_config
        NSD-->>NSN_A: SSE: services_ack
        NSD-->>NSN_A: SSE: dns_config
        NSD-->>NSGW: SSE: wg_config (NSN 全量 peer 列表)
        NSD-->>NSGW: SSE: routing_config
        NSD-->>NSN_B: SSE: dns_config
        NSD-->>NSC: SSE: dns_config
        NSD-->>NSN_A: 204
    end

    rect rgb(255, 248, 240)
        Note over NSGW,NSD: 事件源 2：NSGW 注册 / 地址变化
        NSGW->>NSD: POST /api/v1/gateway/report { gateway_id, wg_pubkey, wg_endpoint, wss_endpoint }
        NSD->>NSD: DNS 解析 wg_endpoint<br/>gateways[gateway_id] = record
        NSD-->>NSN_A: SSE: wg_config (更新的 NSGW peer 列表)
        NSD-->>NSN_B: SSE: wg_config
        NSD-->>NSN_A: SSE: gateway_config
        NSD-->>NSN_B: SSE: gateway_config
        NSD-->>NSC: SSE: gateway_config
        NSD-->>NSGW: 204
    end

    rect rgb(248, 255, 240)
        Note over NSD,NSN_A: 事件源 3：订阅建立（冷启动快照）
        NSN_A->>NSD: GET /api/v1/config/stream (Bearer jwt)
        NSD->>NSD: addSubscriber(machineId)<br/>查 registry 现状
        alt 该 NSN 已上报 services
            NSD-->>NSN_A: 立即 push wg/gateway/proxy/services_ack/dns
        else 仅 gateway
            NSD-->>NSN_A: 立即 push wg (NSN 全量) + routing
        else 其他
            NSD-->>NSN_A: 立即 push gateway_config (若存在 NSGW)
        end
    end
