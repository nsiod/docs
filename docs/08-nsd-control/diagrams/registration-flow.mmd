%% Device registration timing (NSN → NSD).
%% Covers auth_key and device_flow paths followed by signature-based JWT issuance.
%% Source: tests/docker/nsd-mock/src/auth.ts + crates/control/src/auth.rs + device_flow.rs
sequenceDiagram
    autonumber
    participant NSN
    participant NSD
    participant Browser as User Browser

    NSN->>NSN: 本地生成 machinekey (Ed25519)<br/>和 peerkey (X25519)

    NSN->>NSD: GET /api/v1/info
    NSD-->>NSN: { type, realm, auth_methods, nsd_noise_pubkey, nsd_quic_pubkey }

    alt 路径 A：auth_key
        NSN->>NSD: POST /api/v1/machine/register<br/>{ auth_key, machine_id?, machine_key_pub, peer_key_pub, hostname, os, version, system_info }
        NSD->>NSD: 校验 auth_key<br/>写 machines[machine_id]
        NSD-->>NSN: 201 { machine_id, server_peer_key_pub, server_endpoint, domain_base, nsd_noise_pubkey, nsd_quic_pubkey }
    else 路径 B：device flow (RFC 8628)
        NSN->>NSD: POST /api/v1/device/code { client_id }
        NSD-->>NSN: { device_code, user_code, verification_uri, verification_uri_complete, expires_in, interval }
        NSN-->>Browser: 打印 verification_uri + user_code
        Browser->>NSD: 用户在浏览器登录并批准 user_code
        loop 每 interval 秒
            NSN->>NSD: POST /api/v1/device/token { device_code, grant_type }
            alt 未批准
                NSD-->>NSN: 428 { error: "authorization_pending" }
            else 批准
                NSD-->>NSN: 200 { access_token }
            end
        end
        NSN->>NSD: POST /api/v1/machine/register<br/>Authorization: Bearer access_token
        NSD->>NSD: 校验 Bearer token<br/>写 machines[machine_id]
        NSD-->>NSN: 201 { machine_id, ... }
    end

    NSN->>NSN: 写 state: machinekey.json +<br/>registrations/{realm}.json (0600)

    Note over NSN,NSD: 之后的每次启动/重连都走签名认证
    NSN->>NSN: timestamp = unix_secs(now)<br/>sig = Ed25519.sign(signing_key, "{machine_id}:{timestamp}")
    NSN->>NSD: POST /api/v1/machine/auth<br/>{ machine_id, machine_key_pub, timestamp, signature }
    NSD->>NSD: 查 machines[machine_id]<br/>skew ≤ 300s<br/>Ed25519.verify
    NSD-->>NSN: 200 { token: jwt }

    NSN->>NSD: POST /api/v1/services/report<br/>Authorization: Bearer jwt
    NSD-->>NSN: 204
    NSN->>NSD: GET /api/v1/config/stream<br/>Authorization: Bearer jwt
    NSD-->>NSN: SSE: wg_config + gateway_config + proxy_config +<br/>services_ack + dns_config (初始快照)
