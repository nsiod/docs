%% Core NSD data model ER diagram.
%% Mock entities from tests/docker/nsd-mock/src/{auth.ts,registry.ts,types.ts}
%% Production entities from tmp/control/server/db/pg/schema/schema.ts
erDiagram
    REALM ||--o{ MACHINE     : "包含"
    REALM ||--o{ GATEWAY     : "包含"
    REALM ||--o{ AUTHKEY     : "作用域"
    REALM ||--o{ ORG         : "可选映射"

    MACHINE ||--o{ SERVICE      : "上报"
    MACHINE ||--o{ HEARTBEAT    : "发送"
    MACHINE ||--o{ DEVICE_CODE  : "审批"
    MACHINE ||--|| MACHINE_KEYS : "固定"

    GATEWAY ||--o{ ROUTE        : "承载"
    SERVICE ||--o{ PORT_MAPPING : "分配虚拟端口"
    SERVICE ||--o{ DNS_RECORD   : "产出"
    SERVICE ||--o{ SUBNET_RULE  : "生成 DNAT"

    ORG      ||--o{ SITE     : "拥有"
    SITE     ||--o{ RESOURCE : "暴露"
    RESOURCE ||--o{ TARGET   : "映射到"
    USER     ||--o{ USER_ORG : "属于"
    USER     ||--o{ SESSION  : "登录"

    REALM {
        string realm_name  PK
        string type        "cloud|selfhosted"
        string provider
    }

    MACHINE {
        string machine_id        PK
        string realm             FK
        string type              "connector|gateway"
        json   system_info
        int    last_heartbeat_ms
    }

    MACHINE_KEYS {
        string machine_id     PK
        string machine_key_pub "hex Ed25519 (32B)"
        string peer_key_pub    "hex X25519 (32B)"
    }

    GATEWAY {
        string gateway_id   PK
        string realm        FK
        string wg_pubkey    "hex"
        string wg_endpoint  "ip:port"
        string wss_endpoint "wss://..."
    }

    AUTHKEY {
        string key_hash  PK
        string realm     FK
        int    usage_left
        int    expires_at
        string bound_org_id
    }

    DEVICE_CODE {
        string device_code PK
        string user_code
        string access_token
        int    expires_at
        int    approved_at
    }

    SERVICE {
        string machine_id   FK
        string name         "部分 FQID"
        string protocol     "tcp|udp|both"
        string host
        int    port
        bool   enabled
        string tunnel       "auto|wg|ws"
        string gateway_pref "auto|id"
    }

    PORT_MAPPING {
        string fqid         PK "name.machine_id.n.ns"
        int    listen_port     "≥ 10000"
        string target_host
        int    target_port
        string protocol
    }

    SUBNET_RULE {
        string resource_id    PK "= fqid"
        string source_prefix
        string dest_prefix
        string rewrite_type   "ip|cidr|domain"
        string rewrite_value
        string protocol
    }

    DNS_RECORD {
        string domain   PK "name.machine_id.n.ns"
        string site
        string service
        int    port
    }

    ROUTE {
        string domain     PK
        string site
        string service
        int    port
        string nsn_wg_ip   "mock only"
        int    virtual_port "mock only"
    }

    ORG {
        string org_id  PK
        string name
        string subnet
    }

    USER {
        string user_id PK
        string email
        string type    "internal|oidc"
    }

    USER_ORG {
        string user_id FK
        string org_id  FK
        bool   is_owner
    }

    SITE {
        int    site_id   PK
        string org_id    FK
        string subnet
        bool   online
    }

    RESOURCE {
        int    resource_id PK
        string org_id      FK
        string full_domain
        string protocol
    }

    TARGET {
        int    target_id    PK
        int    resource_id  FK
        int    site_id      FK
        string ip
        int    port
    }

    SESSION {
        string session_id PK
        string user_id    FK
        int    expires_at
    }

    HEARTBEAT {
        string machine_id   FK
        int    uptime_secs
        string local_ips    "JSON array"
        int    received_at
    }
