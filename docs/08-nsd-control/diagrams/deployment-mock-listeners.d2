direction: right

BUN: "Bun Server\n:3000"
HTTP: "HTTP/SSE Routes"
NOISE: "Noise listener\n:4001\nRust TLS proxy?"
QUIC: "QUIC listener\n:4002\nspawn nsd-quic-proxy"
