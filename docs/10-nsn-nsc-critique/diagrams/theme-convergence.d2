  t_b: { style: { fill: "#fdd"; stroke: "#000000" } }
  t_c: { style: { fill: "#fde"; stroke: "#000000" } }
  t_d: { style: { fill: "#ffd"; stroke: "#000000" } }
  t_e: { style: { fill: "#dfe"; stroke: "#000000" } }
