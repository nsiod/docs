%% 健康检查与 GatewayEvent → AppState → Monitor API 数据流
%% 源: crates/connector/src/multi.rs (GatewayEvent),
%%    crates/nsn/src/main.rs (drain task, apply_gateway_event),
%%    crates/nsn/src/state.rs, monitor.rs, health.rs
graph TB
    subgraph Producers["事件生产者"]
        MGW["MultiGatewayManager<br/>mark_connected / failed / reconnecting<br/>(connector/src/multi.rs)"]
        TWG["tunnel-wg<br/>GatewayStatusUpdate rx loop<br/>(main.rs:921)"]
        TWS["tunnel-ws<br/>WssConnectionEvent::{Open, Close}<br/>(main.rs:760)"]
        NATE["nat engine<br/>NatStats atomic counters"]
        ACLE["acl engine<br/>denial events"]
    end

    subgraph Channels["tokio::mpsc"]
        GE["GatewayEvent (cap 64)<br/>(main.rs:629)"]
        WE["WssConnectionEvent (cap 128)"]
        GS["GatewayStatusUpdate (cap 16)"]
    end

    subgraph Drains["drain tasks"]
        DR_GW["apply_gateway_event()<br/>(main.rs:1062-1110)"]
        DR_WS["WssConnectionEvent loop<br/>(main.rs:763)"]
        DR_STATUS["gw_status_rx loop<br/>(main.rs:921)"]
    end

    subgraph AppState["AppState (state.rs)"]
        GST["gateway_states: DashMap"]
        TMET["tunnel_metrics: DashMap"]
        CTRK["connection_tracker"]
        NSTATE["nat_stats"]
        ASTATE["acl_state"]
        TFLAG["transport flags"]
    end

    subgraph Readers["Monitor API (monitor.rs + health.rs)"]
        HZ["/healthz"]
        ST["/api/status"]
        GW["/api/gateways"]
        TN["/api/tunnels"]
        CN["/api/connections"]
        NT["/api/nat"]
        ACL_API["/api/acl"]
        METR["/api/metrics (Prometheus)"]
    end

    MGW -->|Connected<br/>Disconnected<br/>Reconnecting<br/>LatencyUpdate| GE
    TWG -->|BytesTransferred<br/>HandshakeCompleted| GE
    TWG --> GS
    GS --> DR_STATUS
    DR_STATUS --> TMET
    DR_STATUS --> GST
    TWS --> WE
    WE --> DR_WS
    DR_WS --> CTRK
    NATE --> NSTATE
    ACLE --> ASTATE
    GE --> DR_GW
    DR_GW --> GST

    GST --> HZ
    GST --> ST
    GST --> GW
    TFLAG --> HZ
    TFLAG --> ST
    TMET --> TN
    CTRK --> CN
    CTRK --> ST
    NSTATE --> NT
    NSTATE --> ST
    ASTATE --> ACL_API
    ASTATE --> ST
    NSTATE --> METR
    GST --> METR
    CTRK --> METR

    classDef producer fill:#fff3e0,stroke:#f57c00
    classDef channel fill:#f3e5f5,stroke:#7b1fa2
    classDef state fill:#e3f2fd,stroke:#1976d2
    classDef reader fill:#e8f5e9,stroke:#388e3c
    class MGW,TWG,TWS,NATE,ACLE producer
    class GE,WE,GS channel
    class GST,TMET,CTRK,NSTATE,ASTATE,TFLAG state
    class HZ,ST,GW,TN,CN,NT,ACL_API,METR reader
    class DR_GW,DR_WS,DR_STATUS channel
