%% NSGW 生产态架构图 (目标状态)
%% 对照 nsgw-vision.md 中 G1-G6 六大能力簇

graph TB
  subgraph CLIENT[客户端]
    NSC[NSC 客户端]
    NSN[NSN 站点节点]
    THIRD[第三方客户端<br/>浏览器/移动]
  end

  subgraph NSGWPOP[NSGW PoP 边缘节点]
    subgraph INGRESS[入口层]
      ANY[Anycast DNS]
      LBL4[L4 LB]
      PROXYV1[PROXY protocol v1<br/>main.go:134-223]
    end
    subgraph CONN[接入 G1]
      WG[Kernel WireGuard<br/>wgctrl]
      WSS[WSS Relay<br/>TLS 1.3]
      QUIC[QUIC/HTTP3]
      HP[Hole Punch<br/>relay.go:21-33]
    end
    subgraph ROUTE[路由 G2]
      SNI[SNI Proxy<br/>proxy.go]
      UDPR[UDP Relay<br/>relay.go]
      L7[L7 HTTP 路由]
      ACL[ACL 检查]
    end
    subgraph SEC[安全 G3]
      TLS[TLS 终止]
      MTLS[mTLS 客户端认证]
      RL2[Rate Limit]
      DDOS[DDoS 缓解]
    end
    subgraph RES[韧性 G4]
      HC[健康检查<br/>/healthz]
      GS[Graceful Shutdown<br/>main.go:404-424]
      FO[Failover 调度]
      MEM[内存水位<br/>monitorMemory]
    end
    subgraph TEL[观测 G5]
      METRIC[Prometheus 指标]
      PP[pprof endpoint]
      BW[periodicBandwidthCheck]
      TRACE[OTel Trace]
    end
    subgraph CAP[资源 G6]
      CPU[CPU quota]
      POOL[连接池]
      EDGE[边缘计算 hook]
    end
  end

  subgraph CTRL[控制面]
    NSD[NSD 控制面<br/>下发 peer 配置]
  end

  subgraph UP[上游]
    BACKEND[后端服务]
    PEER[对端 NSGW/NSN]
  end

  NSC --> ANY
  NSN --> ANY
  THIRD --> ANY
  ANY --> LBL4 --> PROXYV1 --> INGRESS
  INGRESS --> CONN
  CONN --> WG
  CONN --> WSS
  CONN --> QUIC
  CONN --> HP
  CONN --> ROUTE
  ROUTE --> SEC
  SEC --> BACKEND
  SEC --> PEER
  NSGWPOP --> TEL
  NSGWPOP --> RES
  NSGWPOP --> CAP
  NSD -->|配置/peer 列表/ACL| NSGWPOP
  TEL -->|指标回传| NSD

  classDef client fill:#e1f5fe
  classDef ingress fill:#fff3e0
  classDef g1 fill:#e8f5e9
  classDef g2 fill:#f3e5f5
  classDef g3 fill:#ffcdd2
  classDef g4 fill:#e0f7fa
  classDef g5 fill:#fff9c4
  classDef g6 fill:#f1f8e9
  classDef ctrl fill:#e3f2fd
  classDef up fill:#f5f5f5
  class NSC,NSN,THIRD client
  class ANY,LBL4,PROXYV1 ingress
  class WG,WSS,QUIC,HP g1
  class SNI,UDPR,L7,ACL g2
  class TLS,MTLS,RL2,DDOS g3
  class HC,GS,FO,MEM g4
  class METRIC,PP,BW,TRACE g5
  class CPU,POOL,EDGE g6
  class NSD ctrl
  class BACKEND,PEER up
