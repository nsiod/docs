# Other lock files can appear if mixed tooling — keep or drop per policy
pnpm-lock.yaml
package-lock.json
yarn.lock

# Review artifacts
.code-review-graph/

# Core dumps (repo root only — avoid swallowing ./core/ dirs or core.md files)
/core
/core.*
